mapfile -t VERIFY_LINES < <(
ok(){ echo "[OK]   $*"; }
bad(){ echo "[BAD]  $*"; }
warn(){ echo "[WARN] $*"; }
skip(){ echo "[SKIP] $*"; }
info(){ echo "[INFO] $*"; }
info "Local user: $LOCAL_USER"
info "Service user: $SVC_USER"
info "Shared group: $OLLAMA_GROUP"
if getent group "$OLLAMA_GROUP" >/dev/null 2>&1;then
  ok "Group exists: $OLLAMA_GROUP"
else
  bad "Group missing: $OLLAMA_GROUP"
